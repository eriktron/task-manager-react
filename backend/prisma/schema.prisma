//ESTE ARCHIVO, DEFINE LA Estructura de la Base de Datos

//Genera el codigo para conectarse a la Base de Datos
generator client {
  provider = "prisma-client-js"
}

//Aqui se define a que Base de Datos conectarse
datasource db {
  provider = "postgresql"
}

//MODEL: como se llaman las tablas y que columnas tienen
model Task{
  id  Int @id @default(autoincrement())
  title String
  completed Boolean @default(false)
}
